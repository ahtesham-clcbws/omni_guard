{
    "name": "omniguard/omniguard",
    "description": "A simple and friendly helper for managing roles and permissions in Laravel applications. Lightweight, easy to setup, and optimized for shared hosting.",
    "type": "library",
    "license": "proprietary",
    "keywords": [
        "laravel",
        "php",
        "authorization",
        "permissions",
        "rbac",
        "helper",
        "security"
    ],
    "authors": [
        {
            "name": "Ahtesham",
            "homepage": "https://github.com/ahtesham-clcbws",
            "role": "Lead Architect"
        },
        {
            "name": "Broadway Web Services",
            "homepage": "https://www.clcbws.com",
            "role": "Company"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/auth": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "roave/better-reflection": "^6.0",
        "orchestra/testbench": "^9.0",
        "calebporzio/sushi": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "OmniGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OmniGuard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "OmniGuard\\OmniGuardServiceProvider"
            ],
            "aliases": {
                "OmniGuard": "OmniGuard\\Facades\\OmniGuard"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
